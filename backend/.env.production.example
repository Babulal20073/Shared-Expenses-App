# Backend environment variables for production deployment
# Copy this file to .env and fill in real values

# ---- Database ----
# For production use PostgreSQL (Railway/Supabase/Render give you one free)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# For local SQLite (dev only):
# DATABASE_URL=sqlite:///./shared_expenses.db

# ---- Security ----
SECRET_KEY=change-me-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- App ----
ENVIRONMENT=production
